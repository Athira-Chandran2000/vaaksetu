# ─── [REQUIRED] Groq Cloud API — FREE tier ───────────────────────────────────
# Powers: Semantic interpretation of citizen speech + verification restatement
# Model : llama-3.3-70b-versatile (high performance, low latency)
# Get key: https://console.groq.com/  (free for developers)
GROQ_API_KEY="your_groq_key_here"

SARVAM_API_KEY="your_sarvam_key_here"
#
# Without SARVAM_API_KEY, audio upload returns a placeholder message.
# Text-based processing always works with just GROQ_API_KEY.
